import os
import time
import json
import fitz  # pymupdf
import requests
import docx as docx_lib  # python-docx
import openpyxl  # openpyxl para Excel
import concurrent.futures  # Para subida en paralelo
from watchdog.observers import Observer
from watchdog.events import FileSystemEventHandler

# Credenciales — rellena con las tuyas
GEMINI_KEY = ""
SUPABASE_URL = ""
SUPABASE_ANON_KEY = ""

# Carpeta a vigilar
CARPETA = r""

# Carpeta raíz del gestor de WordPress (para calcular la ruta relativa)
CARPETA_WORDPRESS = r""

# Opción C: tamaño de bloque aumentado para generar menos bloques por archivo
TAMANO_BLOQUE = 1500

# Límite máximo de tamaño de archivo en MB
LIMITE_MB = 30

# Opción A: número de bloques a subir en paralelo
BLOQUES_PARALELOS = 5

# Extensiones de archivo soportadas
EXTENSIONES = (".pdf", ".docx", ".xlsx", ".txt")

# Archivo para registrar los archivos ya procesados con su fecha de modificación
REGISTRO = os.path.join(os.path.dirname(__file__), "pdfs_procesados.json")


def cargar_registro():
    """Carga el registro de archivos procesados con su fecha de modificación."""
    if os.path.exists(REGISTRO):
        with open(REGISTRO, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}


def guardar_registro(procesados):
    """Guarda el registro de archivos procesados."""
    with open(REGISTRO, "w", encoding="utf-8") as f:
        json.dump(procesados, f, ensure_ascii=False, indent=2)


def extraer_texto(ruta):
    """Extrae el texto de un PDF, Word, Excel o TXT."""
    extension = os.path.splitext(ruta)[1].lower()
    if extension == ".pdf":
        doc = fitz.open(ruta)
        texto = ""
        for pagina in doc:
            texto += pagina.get_text() + "\n"
        doc.close()
        return texto
    elif extension == ".docx":
        doc = docx_lib.Document(ruta)
        texto = "\n".join([parrafo.text for parrafo in doc.paragraphs if parrafo.text.strip()])
        return texto
    elif extension == ".xlsx":
        wb = openpyxl.load_workbook(ruta, data_only=True)
        lineas = []
        for hoja in wb.worksheets:
            lineas.append(f"Hoja: {hoja.title}")
            for fila in hoja.iter_rows(values_only=True):
                celdas = [str(c) for c in fila if c is not None]
                if celdas:
                    lineas.append(" | ".join(celdas))
        return "\n".join(lineas)
    elif extension == ".txt":
        with open(ruta, "r", encoding="utf-8", errors="ignore") as f:
            return f.read()
    else:
        raise Exception(f"Formato no soportado: {extension}")


def trocear_texto(texto):
    """Trocea el texto en bloques para los embeddings."""
    bloques = []
    inicio = 0
    while inicio < len(texto):
        fin = inicio + TAMANO_BLOQUE
        if fin < len(texto):
            ultimo_punto = texto.rfind(".", inicio, fin)
            if ultimo_punto > inicio + 200:
                fin = ultimo_punto + 1
        bloque = texto[inicio:fin].strip()
        if len(bloque) > 50:
            bloques.append(bloque)
        inicio = fin
    return bloques


def generar_embedding(texto):
    """Genera el embedding de un texto con Gemini."""
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key={GEMINI_KEY}"
    body = {
        "model": "models/gemini-embedding-001",
        "content": {"parts": [{"text": texto}]}
    }
    res = requests.post(url, json=body)
    data = res.json()
    if "embedding" not in data:
        raise Exception(f"Error generando embedding: {data}")
    return data["embedding"]["values"]


def obtener_ruta_wordpress(ruta_absoluta):
    """Calcula la ruta relativa del archivo dentro del gestor de WordPress."""
    try:
        # Intentar obtener ruta relativa desde la carpeta de WordPress
        ruta_rel = os.path.relpath(ruta_absoluta, CARPETA_WORDPRESS)
        # Normalizar separadores a /
        return ruta_rel.replace("\\", "/")
    except ValueError:
        # Si el archivo no está bajo CARPETA_WORDPRESS usar ruta relativa desde CARPETA
        ruta_rel = os.path.relpath(ruta_absoluta, CARPETA)
        return ruta_rel.replace("\\", "/")


def borrar_documentos_pdf(nombre_pdf):
    """Borra de Supabase todos los bloques de un archivo por su nombre."""
    url = f"{SUPABASE_URL}/rest/v1/documentos?nombre_pdf=eq.{nombre_pdf}"
    headers = {
        "apikey": SUPABASE_ANON_KEY,
        "Authorization": f"Bearer {SUPABASE_ANON_KEY}"
    }
    res = requests.delete(url, headers=headers)
    if not res.ok:
        raise Exception(f"Error borrando documentos: {res.text}")
    print(f"   🗑️  Bloques anteriores de {nombre_pdf} eliminados")


def insertar_documento(contenido, embedding, nombre_pdf, ruta_archivo):
    """Inserta un bloque en Supabase con el nombre y ruta del archivo origen."""
    url = f"{SUPABASE_URL}/rest/v1/documentos"
    headers = {
        "Content-Type": "application/json",
        "apikey": SUPABASE_ANON_KEY,
        "Authorization": f"Bearer {SUPABASE_ANON_KEY}",
        "Prefer": "return=minimal"
    }
    body = {
        "contenido": contenido,
        "nombre_pdf": nombre_pdf,
        "ruta_archivo": ruta_archivo,
        "embedding": f"[{','.join(map(str, embedding))}]"
    }
    res = requests.post(url, json=body, headers=headers)
    if not res.ok:
        raise Exception(f"Error insertando en Supabase: {res.text}")


def procesar_bloque(args):
    """Procesa un bloque individual: genera embedding y lo sube. Usado en paralelo."""
    indice, total, bloque, nombre, ruta_archivo = args
    print(f"   🔹 Subiendo bloque {indice + 1}/{total}...")
    embedding = generar_embedding(bloque)
    insertar_documento(bloque, embedding, nombre, ruta_archivo)
    # Opción B: pausa reducida entre peticiones
    time.sleep(0.5)
    return True


def procesar_pdf(ruta_pdf, es_actualizacion=False):
    """Procesa un archivo completo y lo sube a Supabase con bloques en paralelo."""
    nombre = os.path.basename(ruta_pdf)
    accion = "Actualizando" if es_actualizacion else "Procesando"
    print(f"\n📄 {accion}: {nombre}")

    # Límite de tamaño de archivo
    tamano_mb = os.path.getsize(ruta_pdf) / (1024 * 1024)
    if tamano_mb > LIMITE_MB:
        print(f"   ⚠️  Archivo demasiado grande ({tamano_mb:.1f} MB, límite {LIMITE_MB} MB) — omitido")
        return False

    try:
        if es_actualizacion:
            borrar_documentos_pdf(nombre)

        texto = extraer_texto(ruta_pdf)
        print(f"   Texto extraído: {len(texto)} caracteres")

        bloques = trocear_texto(texto)
        print(f"   Bloques generados: {len(bloques)} (subiendo {BLOQUES_PARALELOS} en paralelo)")

        # Calcular ruta relativa para el gestor de WordPress
        ruta_archivo = obtener_ruta_wordpress(ruta_pdf)
        print(f"   📂 Ruta WordPress: {ruta_archivo}")

        # Opción A: subir bloques en paralelo
        args = [(i, len(bloques), bloque, nombre, ruta_archivo) for i, bloque in enumerate(bloques)]
        with concurrent.futures.ThreadPoolExecutor(max_workers=BLOQUES_PARALELOS) as executor:
            resultados = list(executor.map(procesar_bloque, args))

        if all(resultados):
            print(f"   ✅ {nombre} subido correctamente")
            return True
        else:
            print(f"   ⚠️  {nombre} subido con algunos errores")
            return False

    except Exception as e:
        print(f"   ❌ Error procesando {nombre}: {e}")
        return False


def revisar_pendientes(procesados):
    """Cola de pendientes: revisa la carpeta al arrancar y sube los archivos nuevos o modificados."""
    print("🔍 Revisando carpeta en busca de archivos pendientes...")
    pendientes = 0

    # Detección de borrados: archivos en el registro que ya no existen en ninguna subcarpeta
    todos_los_archivos = set()
    for carpeta_actual, _, archivos in os.walk(CARPETA):
        for archivo in archivos:
            if archivo.lower().endswith(EXTENSIONES):
                todos_los_archivos.add(archivo)

    borrados = [nombre for nombre in list(procesados.keys()) if nombre not in todos_los_archivos]

    for nombre in borrados:
        print(f"   🗑️  Detectado borrado mientras estaba apagado: {nombre}")
        try:
            borrar_documentos_pdf(nombre)
            del procesados[nombre]
            guardar_registro(procesados)
            print(f"   ✅ {nombre} eliminado de Supabase correctamente")
        except Exception as e:
            print(f"   ❌ Error eliminando {nombre}: {e}")

    for carpeta_actual, _, archivos in os.walk(CARPETA):
        for archivo in archivos:
            if not archivo.lower().endswith(EXTENSIONES):
                continue

            ruta = os.path.join(carpeta_actual, archivo)
            fecha_actual = os.path.getmtime(ruta)
            fecha_guardada = procesados.get(archivo)

            if fecha_guardada is None:
                print(f"   📋 Pendiente nuevo: {archivo}")
                exito = procesar_pdf(ruta, es_actualizacion=False)
                if exito:
                    procesados[archivo] = fecha_actual
                    guardar_registro(procesados)
                pendientes += 1

            elif abs(fecha_actual - fecha_guardada) > 1:
                print(f"   🔄 Pendiente modificado: {archivo}")
                exito = procesar_pdf(ruta, es_actualizacion=True)
                if exito:
                    procesados[archivo] = fecha_actual
                    guardar_registro(procesados)
                pendientes += 1

    if pendientes == 0:
        print("   ✅ No hay archivos pendientes.")
    else:
        print(f"   ✅ {pendientes} archivo(s) pendiente(s) procesados.")


class ManejadorPDF(FileSystemEventHandler):
    """Detecta nuevos archivos, modificaciones, borrados y renombrados."""

    def __init__(self, procesados):
        self.procesados = procesados
        # Almacena temporalmente rutas de archivos movidos/renombrados
        self._pendiente_renombrado = {}
        # Control para evitar procesar el mismo archivo dos veces a la vez
        self._en_proceso = set()

    def _gestionar_pdf(self, ruta):
        """Lógica común para archivo nuevo o modificado."""
        if not ruta.lower().endswith(EXTENSIONES):
            return

        nombre = os.path.basename(ruta)

        # Evitar procesar el mismo archivo dos veces simultáneamente
        if nombre in self._en_proceso:
            return
        self._en_proceso.add(nombre)

        time.sleep(2)

        if not os.path.exists(ruta):
            self._en_proceso.discard(nombre)
            return

        fecha_actual = os.path.getmtime(ruta)
        fecha_guardada = self.procesados.get(nombre)

        if fecha_guardada is None:
            exito = procesar_pdf(ruta, es_actualizacion=False)
        elif abs(fecha_actual - fecha_guardada) > 1:
            print(f"\n🔄 Cambio detectado en: {nombre}")
            exito = procesar_pdf(ruta, es_actualizacion=True)
        else:
            print(f"⏭️  {nombre} sin cambios, omitiendo.")
            self._en_proceso.discard(nombre)
            return

        if exito:
            self.procesados[nombre] = fecha_actual
            guardar_registro(self.procesados)

        self._en_proceso.discard(nombre)

    def on_created(self, event):
        if event.is_directory:
            return
        self._gestionar_pdf(event.src_path)

    def on_modified(self, event):
        if event.is_directory:
            return
        self._gestionar_pdf(event.src_path)

    def on_deleted(self, event):
        # Detección de borrado de carpeta con archivos dentro
        if event.is_directory:
            carpeta_borrada = os.path.normpath(event.src_path)
            afectados = [
                nombre for nombre in list(self.procesados.keys())
                if not any(
                    os.path.exists(os.path.join(r, nombre))
                    for r, _, _ in os.walk(CARPETA)
                )
            ]
            if afectados:
                print(f"\n🗑️  Carpeta eliminada: {os.path.basename(carpeta_borrada)}")
                for nombre in afectados:
                    try:
                        borrar_documentos_pdf(nombre)
                        del self.procesados[nombre]
                        guardar_registro(self.procesados)
                        print(f"   ✅ {nombre} eliminado de Supabase correctamente")
                    except Exception as e:
                        print(f"   ❌ Error eliminando {nombre}: {e}")
            return

        if not event.src_path.lower().endswith(EXTENSIONES):
            return

        nombre = os.path.basename(event.src_path)
        if nombre not in self.procesados:
            return

        # Guardar temporalmente por si es un renombrado
        self._pendiente_renombrado[nombre] = time.time()
        time.sleep(1)

        # Si sigue en pendientes después de 1 segundo es un borrado real
        if nombre in self._pendiente_renombrado:
            print(f"\n🗑️  Archivo eliminado: {nombre}")
            try:
                borrar_documentos_pdf(nombre)
                del self.procesados[nombre]
                guardar_registro(self.procesados)
                print(f"   ✅ {nombre} eliminado de Supabase correctamente")
            except Exception as e:
                print(f"   ❌ Error eliminando {nombre} de Supabase: {e}")
            del self._pendiente_renombrado[nombre]

    def on_moved(self, event):
        """Detecta renombrado de archivos (Windows lo trata como movido)."""
        if event.is_directory:
            return

        src = event.src_path
        dst = event.dest_path

        if not src.lower().endswith(EXTENSIONES) and not dst.lower().endswith(EXTENSIONES):
            return

        nombre_antiguo = os.path.basename(src)
        nombre_nuevo = os.path.basename(dst)

        # Cancelar el borrado pendiente si lo había
        if nombre_antiguo in self._pendiente_renombrado:
            del self._pendiente_renombrado[nombre_antiguo]

        if nombre_antiguo not in self.procesados:
            self._gestionar_pdf(dst)
            return

        print(f"\n✏️  Archivo renombrado: {nombre_antiguo} → {nombre_nuevo}")

        try:
            url = f"{SUPABASE_URL}/rest/v1/documentos?nombre_pdf=eq.{nombre_antiguo}"
            headers = {
                "Content-Type": "application/json",
                "apikey": SUPABASE_ANON_KEY,
                "Authorization": f"Bearer {SUPABASE_ANON_KEY}"
            }
            res = requests.patch(url, json={"nombre_pdf": nombre_nuevo}, headers=headers)
            if not res.ok:
                raise Exception(res.text)

            fecha = self.procesados.pop(nombre_antiguo)
            self.procesados[nombre_nuevo] = fecha
            guardar_registro(self.procesados)

            print(f"   ✅ Nombre actualizado en Supabase correctamente")

        except Exception as e:
            print(f"   ❌ Error actualizando nombre en Supabase: {e}")


def main():
    print("🤖 Vigilante de archivos — Couce Consulting")
    print(f"📁 Carpeta vigilada: {CARPETA}")

    if not os.path.exists(CARPETA):
        print(f"❌ La carpeta no existe: {CARPETA}")
        return

    # Cola de pendientes: procesar archivos añadidos mientras el script estaba apagado
    procesados = cargar_registro()
    revisar_pendientes(procesados)

    print("\n⏳ Esperando nuevos archivos o cambios...\n")

    manejador = ManejadorPDF(procesados)
    observador = Observer()
    observador.schedule(manejador, CARPETA, recursive=True)
    observador.start()

    print(f"✅ Vigilando activamente: {CARPETA}")

    # Comprobación periódica cada 10 segundos para detectar borrados que watchdog no captura
    ultimo_chequeo = time.time()

    try:
        while True:
            time.sleep(1)
            # Cada 10 mins revisar si hay archivos del registro que ya no existen
            if time.time() - ultimo_chequeo >= 600:
                ultimo_chequeo = time.time()
                todos_los_archivos = set()
                for carpeta_actual, _, archivos in os.walk(CARPETA):
                    for archivo in archivos:
                        if archivo.lower().endswith(EXTENSIONES):
                            todos_los_archivos.add(archivo)
                borrados = [n for n in list(procesados.keys()) if n not in todos_los_archivos]
                for nombre in borrados:
                    print(f"\n🗑️  Archivo desaparecido detectado: {nombre}")
                    try:
                        borrar_documentos_pdf(nombre)
                        del procesados[nombre]
                        guardar_registro(procesados)
                        print(f"   ✅ {nombre} eliminado de Supabase correctamente")
                    except Exception as e:
                        print(f"   ❌ Error eliminando {nombre}: {e}")
    except KeyboardInterrupt:
        print("\n⛔ Vigilante detenido.")
        observador.stop()

    observador.join()


if __name__ == "__main__":
    main()