def calcular_hash_archivo(ruta):
    """Calcula el hash MD5 de un archivo para detectar cambios reales."""
    hash_md5 = hashlib.md5()
    with open(ruta, "rb") as f:
        for chunk in iter(lambda: f.read(4096), b""):
            hash_md5.update(chunk)
    return hash_md5.hexdigest()


def obtener_siguiente_version(nombre_base, carpeta_destino):
    """Obtiene el siguiente número de versión para un archivo."""
    nombre_sin_ext, ext = os.path.splitext(nombre_base)
    version = 1
    
    while True:
        nombre_versionado = f"{nombre_sin_ext}_v{version}{ext}"
        ruta_version = os.path.join(carpeta_destino, nombre_versionado)
        if not os.path.exists(ruta_version):
            return nombre_versionado, ruta_version
        version += 1


def crear_version(ruta_original):
    """Crea una nueva versión del archivo en la carpeta de borradores."""
    nombre_original = os.path.basename(ruta_original)
    nombre_versionado, ruta_destino = obtener_siguiente_version(nombre_original, CARPETA_BORRADORES)
    
    shutil.copy2(ruta_original, ruta_destino)
    logger.info(f"📋 Nueva versión creada: {nombre_versionado}")
    return ruta_destino


