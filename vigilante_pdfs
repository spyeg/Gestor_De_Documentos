def procesar_archivo(ruta_archivo, es_actualizacion=False):
    """Procesa un archivo completo y lo sube a Supabase."""
    nombre = os.path.basename(ruta_archivo)
    accion = "Actualizando" if es_actualizacion else "Procesando"
    
    logger.info(f"\n📄 {accion}: {nombre}")
    
    # Verificar tamaño
    tamano_mb = os.path.getsize(ruta_archivo) / (1024 * 1024)
    if tamano_mb > LIMITE_MB:
        logger.warning(f"   ⚠️ Archivo demasiado grande ({tamano_mb:.1f} MB)")
        return False
    
    try:
        # Si es actualización y está en originales, crear nueva versión
        if es_actualizacion and CARPETA_ORIGINALES in ruta_archivo:
            logger.info(f"   🔄 Creando nueva versión...")
            mover_a_historico(ruta_archivo)
            return True
        
        # Eliminar versión anterior si es actualización
        if es_actualizacion:
            borrar_documentos_supabase(nombre)
        
        # Extraer texto
        texto = extraer_texto(ruta_archivo)
        logger.info(f"   Texto extraído: {len(texto)} caracteres")
        
        if not texto.strip():
            logger.warning(f"   ⚠️ El archivo no contiene texto extraíble")
            return False
        
        # Trocear en bloques
        bloques = trocear_texto(texto)
        logger.info(f"   Bloques generados: {len(bloques)}")
        
        if not bloques:
            logger.warning(f"   ⚠️ No se generaron bloques")
            return False
        
        # Ruta WordPress
        ruta_wp = obtener_ruta_wordpress(ruta_archivo)
        logger.info(f"   📂 Ruta WordPress: {ruta_wp}")
        
        # Procesar bloques en paralelo
        args = [(i, len(bloques), bloque, nombre, ruta_wp) for i, bloque in enumerate(bloques)]
        
        with concurrent.futures.ThreadPoolExecutor(max_workers=BLOQUES_PARALELOS) as executor:
            resultados = list(executor.map(procesar_bloque, args))
        
        if all(resultados):
            logger.info(f"   ✅ {nombre} procesado correctamente")
            return True
        else:
            logger.warning(f"   ⚠️ {nombre} procesado con errores parciales")
            return False
            
    except Exception as e:
        logger.error(f"   ❌ Error procesando {nombre}: {e}")
        logger.error(traceback.format_exc())
        return False


def eliminar_archivo_supabase(nombre_archivo):
    """Elimina un archivo de Supabase."""
    logger.info(f"\n🗑️ Eliminando: {nombre_archivo}")
    
    try:
        exito = borrar_documentos_supabase(nombre_archivo)
        if exito:
            logger.info(f"   ✅ {nombre_archivo} eliminado de Supabase")
        return exito
    except Exception as e:
        logger.error(f"   ❌ Error eliminando {nombre_archivo}: {e}")
        return False


def sincronizar_inicial():
    """Sincroniza todos los archivos existentes al iniciar."""
    logger.info("=" * 60)
    logger.info("🔄 SINCRONIZACIÓN INICIAL")
    logger.info("=" * 60)
    
    procesados = cargar_registro()
    archivos_actuales = {}
    
    # Recopilar todos los archivos actuales
    for carpeta in [CARPETA_ORIGINALES, CARPETA_BORRADORES]:
        if not os.path.exists(carpeta):
            continue
        
        for root, dirs, files in os.walk(carpeta):
            for archivo in files:
                if archivo.lower().endswith(EXTENSIONES):
                    ruta = os.path.join(root, archivo)
                    archivos_actuales[archivo] = {
                        "ruta": ruta,
                        "fecha": os.path.getmtime(ruta),
                        "hash": calcular_hash_archivo(ruta)
                    }
    
    # Detectar archivos nuevos o modificados
    nuevos = 0
    modificados = 0
    
    for nombre, info in archivos_actuales.items():
        if nombre not in procesados:
            logger.info(f"📋 Nuevo archivo detectado: {nombre}")
            if procesar_archivo(info["ruta"], es_actualizacion=False):
                procesados[nombre] = {
                    "fecha": info["fecha"],
                    "hash": info["hash"]
                }
                nuevos += 1
        else:
            fecha_guardada = procesados[nombre].get("fecha", 0) if isinstance(procesados[nombre], dict) else procesados[nombre]
            if abs(info["fecha"] - fecha_guardada) > 1:
                logger.info(f"🔄 Archivo modificado: {nombre}")
                if procesar_archivo(info["ruta"], es_actualizacion=True):
                    procesados[nombre] = {
                        "fecha": info["fecha"],
                        "hash": info["hash"]
                    }
                    modificados += 1
    
    # Detectar archivos eliminados
    eliminados = []
    for nombre in list(procesados.keys()):
        if nombre not in archivos_actuales:
            logger.info(f"🗑️ Archivo eliminado detectado: {nombre}")
            if eliminar_archivo_supabase(nombre):
                eliminados.append(nombre)
    
    # Limpiar registro de eliminados
    for nombre in eliminados:
        del procesados[nombre]
    
    # Guardar registro
    guardar_registro(procesados)
    
    logger.info("=" * 60)
    logger.info(f"✅ Sincronización completada:")
    logger.info(f"   Nuevos: {nuevos}")
    logger.info(f"   Modificados: {modificados}")
    logger.info(f"   Eliminados: {len(eliminados)}")
    logger.info("=" * 60)
    
    return procesados


