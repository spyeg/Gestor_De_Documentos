# VIGILANTE DE ARCHIVOS
# ============================================

class VigilanteHandler(FileSystemEventHandler):
    """Manejador de eventos del sistema de archivos."""
    
    def __init__(self, procesados):
        self.procesados = procesados
        self._en_proceso = set()
        self._cooldown = {}  # Evitar procesamiento duplicado
        logger.info("✅ Vigilante iniciado")
    
    def _debe_procesar(self, ruta):
        """Verifica si el archivo debe ser procesado."""
        if not ruta.lower().endswith(EXTENSIONES):
            return False
        
        nombre = os.path.basename(ruta)
        
        # Evitar procesar el mismo archivo muy rápido
        if nombre in self._cooldown:
            if time.time() - self._cooldown[nombre] < 3:
                return False
        
        # Evitar procesar archivos temporales
        if nombre.startswith(('.', '~', 'tmp')):
            return False
        
        return True
    
    def _procesar(self, ruta, es_creacion=False):
        """Procesa un archivo."""
        if not self._debe_procesar(ruta):
            return
        
        nombre = os.path.basename(ruta)
        
        # Evitar procesamiento concurrente
        if nombre in self._en_proceso:
            return
        
        self._en_proceso.add(nombre)
        self._cooldown[nombre] = time.time()
        
        # Pequeña pausa para asegurar que el archivo está completamente escrito
        time.sleep(1)
        
        if not os.path.exists(ruta):
            self._en_proceso.discard(nombre)
            return
        
        try:
            fecha_actual = os.path.getmtime(ruta)
            hash_actual = calcular_hash_archivo(ruta)
            
            registro = self.procesados.get(nombre)
            
            # Verificar si es nuevo o modificado
            if not registro:
                logger.info(f"📄 Nuevo archivo detectado: {nombre}")
                exito = procesar_archivo(ruta, es_actualizacion=False)
                
                if exito:
                    self.procesados[nombre] = {
                        "fecha": fecha_actual,
                        "hash": hash_actual
                    }
                    guardar_registro(self.procesados)
                    
            else:
                fecha_guardada = registro.get("fecha", 0) if isinstance(registro, dict) else registro
                hash_guardado = registro.get("hash", "") if isinstance(registro, dict) else ""
                
                if abs(fecha_actual - fecha_guardada) > 1 or hash_actual != hash_guardado:
                    logger.info(f"🔄 Archivo modificado: {nombre}")
                    exito = procesar_archivo(ruta, es_actualizacion=True)
                    
                    if exito:
                        self.procesados[nombre] = {
                            "fecha": fecha_actual,
                            "hash": hash_actual
                        }
                        guardar_registro(self.procesados)
                
        except Exception as e:
            logger.error(f"Error procesando {ruta}: {e}")
        
        finally:
            self._en_proceso.discard(nombre)
    
    def on_created(self, event):
        if event.is_directory:
            return
        self._procesar(event.src_path, es_creacion=True)
    
    def on_modified(self, event):
        if event.is_directory:
            return
        self._procesar(event.src_path, es_creacion=False)
    
    def on_deleted(self, event):
        if event.is_directory:
            return
        
        if not event.src_path.lower().endswith(EXTENSIONES):
            return
        
        nombre = os.path.basename(event.src_path)
        
        if nombre in self.procesados:
            logger.info(f"🗑️ Archivo eliminado: {nombre}")
            if eliminar_archivo_supabase(nombre):
                del self.procesados[nombre]
                guardar_registro(self.procesados)


